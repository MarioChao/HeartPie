{
    "name": "heart-pie",
    "tree": {
        "$className": "DataModel",

        "ReplicatedStorage": {
            "$path": "src/HeartPie/ContainerScripts/ReplicatedStorage",
            "$ignoreUnknownInstances": true
        },
        "ServerScriptService": {
            "$path": "src/HeartPie/ContainerScripts/ServerScriptService",
            "$ignoreUnknownInstances": true
        },
        "ServerStorage": {
            "$path": "src/HeartPie/ContainerScripts/ServerStorage",
            "$ignoreUnknownInstances": true,

            "HeartPie_Module": {
                "$className": "Folder",
                "MainModule": {
                    "$path": "src/HeartPieModule/MainModule",
                    "HeartPie_Package": {
                        "$path": "src/HeartPie"
                    }
                }
            }
        }
    },
    "globIgnorePaths": ["**/wally.toml"]
}